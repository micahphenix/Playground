# Steward (Body Steward) — Environment Variables
# Copy to .env and fill in. Never commit .env.

# Anthropic API key for the coach (chat, photo analysis, voice/text parsing).
# Exposed to the client via Expo's EXPO_PUBLIC_ prefix — fine for dev.
# In production, proxy through a server you control.
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...
